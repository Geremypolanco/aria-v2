ENVIRONMENT=development

# Google OAuth — console.cloud.google.com
GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_client_secret

# JWT — genera con: openssl rand -hex 32
JWT_SECRET=genera-uno-con-openssl-rand-hex-32

# Anthropic — console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — Settings > API en tu proyecto Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...  # service_role key, NO la anon key

# ── APIs & Integrations (Templates) ──────────────────────────
# Reemplaza con tus claves reales en el panel de Vercel o en un archivo .env local
GROQ_API_KEY=gsk_...
HUGGINGFACE_TOKEN=hf_...
NEWS_API_KEY=...
SERP_API_KEY=...
ELEVENLABS_API_KEY=sk_...
STRIPE_SECRET_KEY=sk_test_...
GUMROAD_ACCESS_TOKEN=...
TELEGRAM_BOT_TOKEN=...
BUFFER_TOKEN=...
DID_API_KEY=...
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
CLOUDINARY_URL=cloudinary://...
AIRTABLE_ACCESS_TOKEN=pat...
MAILCHIMP_API_KEY=...
UPSTASH_REDIS_REST_URL=...
UPSTASH_REDIS_REST_TOKEN=...
FLY_IO_TOKEN=...
